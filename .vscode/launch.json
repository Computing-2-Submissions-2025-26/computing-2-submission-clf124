{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Web App – Firefox",
            "type": "firefox",
            "request": "launch",
            "reAttach": true,
            "reloadOnAttach": true,
            "file": "${workspaceFolder}/web-app/index.html",
            "preferences": {
                "security.fileuri.strict_origin_policy": false
            },
            "skipFiles": [
                "${workspaceFolder}/node_modules/**",
                "<node_internals>/**"
            ]
        },
        {
            "name": "Debug Backgammon.js",
            "type": "node",
            "request": "launch",
            "skipFiles": [
                "${workspaceFolder}/node_modules/**",
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/web-app/Backgammon.js"
        },
        {
            "name": "Generate Docs",
            "command": "jsdoc -c jsdoc.json; exit",
            "request": "launch",
            "type": "node-terminal"
        }
    ]
}
